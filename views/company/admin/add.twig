{% extends '_layout/dashboard/layout.twig' %}

{% block title %}Gestion des entreprises{% endblock %}

{% block body %}

    <!-- START .cards -->
    <div class="section--admin">
        <div class="container">
            <form method="post" enctype="multipart/form-data">
                {{ include('_notifications.twig') }}
                <div class="card-custom mg-b-3">
                    <div class="card-body">
                        <div class="card-header m-0">
                            <div class="columns">
                                <div class="col-8 col-sm-12"><h2>Nouvel entreprise</h2><span>Création de mon entreprise</span></div>
                                <div class="col-4 col-sm-12 text-right">
                                    {{ form.submitSingle('primary', 'saveData', 'Sauvegarder', false) | raw }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-custom">
                    <div class="card-body">
                        {{ include('company/admin/_form.twig', {'firstAdd': 1}) }}
                    </div>
                </div>
            </form>
        </div>
    </div>
    <!-- END .cards -->
{% endblock %}