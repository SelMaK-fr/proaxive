{% extends '_layout/dashboard/layout.twig' %}

{% block title %}Nouveau débours{% endblock %}

{% block body %}
    <div class="section--admin">
        <div class="container">
            {{ include('_notifications.twig') }}
            <form method="post">
            <div class="card-custom mg-b-3">
                <div class="card-body">
                    <div class="card-header m-0">
                        <div class="columns">
                            <div class="col-8 col-sm-12"><h2>Nouveau débours</h2><span>Création d'un nouveau débours pour <strong>{{ client.fullname }}</strong></span></div>
                            <div class="col-4 col-sm-12 text-right">
                                {{ form.submitDefault('Sauvegarder', 'primary') | raw }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="admin-content">
                    {{ include('outlay/admin/_form.twig', {'withclient': 1}) }}
            </div>
            </form>
        </div>
    </div>
    <!-- END .cards -->
{% endblock %}