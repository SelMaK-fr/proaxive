{% extends '_layout/dashboard/layout.twig' %}

{% block title %}Débours n° {{ outlay.number }}{% endblock %}

{% block body %}
    <div class="section--admin">
        <div class="container">
            <form method="post">
            {{ include('_notifications.twig') }}
            <div class="card-custom mg-b-3">
                <div class="card-body">
                    <div class="card-header m-0">
                        <div class="columns">
                            <div class="col-8 col-sm-12"><h2>Débours N°{{ outlay.number }}</h2><span>Consulter et modifier un débours existant</span></div>
                            <div class="col-4 col-sm-12 text-right">
                                {{ form.submitDefault('Sauvegarder', 'primary', 'update') | raw }}
                                {{ form.submitDefault('Cloturer', 'info', 'cloture') | raw }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="admin-content">
                {{ include('outlay/admin/_form.twig', {'edit':1}) }}
            </div>
            </form>
        </div>
    </div>
    <!-- END .cards -->
{% endblock %}